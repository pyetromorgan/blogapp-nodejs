<h4>Editar Postagem</h4>
<hr>

<div class="card">
    <div class="card-body">
        <form action="/admin/postagens/editar" method="POST">
            <input type="hidden" name="id" value="{{postagem._id}}">

            <div class="form-group">
                <label for="titulo">Título:</label>
                <input type="text" name="titulo" class="form-control" value="{{postagem.titulo}}" required>
            </div>

            <div class="form-group mt-3">
                <label for="slug">Slug:</label>
                <input type="text" name="slug" class="form-control" value="{{postagem.slug}}" required>
            </div>

            <div class="form-group mt-3">
                <label for="descricao">Descrição:</label>
                <input type="text" name="descricao" class="form-control" value="{{postagem.descricao}}" required>
            </div>

            <div class="form-group mt-3">
                <label for="conteudo">Conteúdo:</label>
                <textarea name="conteudo" class="form-control" rows="5" required>{{postagem.conteudo}}</textarea>
            </div>

            <div class="form-group mt-3">
                <label for="categoria">Categoria:</label>
                <select name="categoria" class="form-select" required>
                    {{#each categorias}}
                        <option value="{{_id}}">{{nome}}</option>
                    {{else}}
                        <option value="0">Nenhuma categoria registrada.</option>
                    {{/each}}
                </select>
            </div>

            <button type="submit" class="btn btn-success mt-4">Salvar Alterações</button>
        </form>
    </div>
</div>
{{#each erros}}
    <div class="alert alert-danger">{{texto}}</div>
{{/each}}

<h4>Nova Postagem</h4>
<hr>

<div class="card">
    <div class="card-body">
        <form action="/admin/postagens/nova" method="POST">
            
            <div class="form-group">
                <label for="titulo">Título:</label>
                <input type="text" id="titulo" name="titulo" placeholder="Título da postagem" class="form-control" required>
            </div>

            <div class="form-group mt-3">
                <label for="slug">Slug:</label>
                <input type="text" id="slug" name="slug" placeholder="Slug da postagem" class="form-control" required>
            </div>

            <div class="form-group mt-3">
                <label for="descricao">Descrição:</label>
                <input type="text" id="descricao" name="descricao" placeholder="Breve descrição do post" class="form-control" required>
            </div>

            <div class="form-group mt-3">
                <label for="conteudo">Conteúdo:</label>
                <textarea id="conteudo" name="conteudo" placeholder="Escreva o conteúdo aqui..." class="form-control" rows="5" required></textarea>
            </div>

            <div class="form-group mt-3">
                <label for="categoria">Categoria:</label>
                <select name="categoria" id="categoria" class="form-select" required>
                    {{#each categorias}}
                        <option value="{{_id}}">{{nome}}</option>
                    {{else}}
                        <option value="0">Nenhuma categoria registrada.</option>
                    {{/each}}
                </select>
            </div>

            <button type="submit" class="btn btn-success mt-4">Criar Postagem</button>
        </form>
    </div>
</div>
<div class="mt-4">
    <h2>Categorias Cadastradas:</h2>
    <hr>
    <div class="list-group">
        {{#each categorias}}
            <a href="/categorias/{{slug}}" class="list-group-item list-group-item-action fs-5">
                📁 {{nome}}
            </a>
        {{else}}
            <div class="alert alert-warning">Nenhuma categoria cadastrada no momento!</div>
        {{/each}}
    </div>
</div>